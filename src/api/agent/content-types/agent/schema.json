{
  "kind": "collectionType",
  "collectionName": "ai_agents",
  "info": {
    "singularName": "agent",
    "pluralName": "agents",
    "displayName": "Agent",
    "description": "AI Agent Personas"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "systemPrompt": {
      "type": "text",
      "required": true
    },
    "icon": {
      "type": "string",
      "required": true,
      "default": "Bot"
    },
    "category": {
      "type": "string",
      "required": true
    },
    "isPublic": {
      "type": "boolean",
      "default": true
    },
    "creator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
